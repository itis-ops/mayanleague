# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.next/dev-server.pid

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# Local env files stay out of git; `.env.example` is committed as the template.
.env
.env.local
.env*.local

# Sanity build artifacts (Studio dist + dev caches)
/dist
.sanity/

# vercel
.vercel

# local image-optimization scratch output
/tmp

# typescript
*.tsbuildinfo
next-env.d.ts
