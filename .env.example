# ─────────────────────────────────────────────────────────────────────────────
# Mayan League — environment variables reference
#
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must NEVER be committed.
#
# For Vercel: paste these in Project → Settings → Environment Variables.
# See SANITY_SETUP.md for step-by-step instructions on obtaining each value.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sanity project ────────────────────────────────────────────────────────────

# Project ID — shown at the top of https://sanity.io/manage
# Used by: Studio (browser), GROQ queries (server), Presentation Tool
NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder-project-id

# Dataset name. The live content lives in "production".
# Used by: Studio, all data queries
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API date-version. Pinned so GROQ behavior stays stable.
# Change only when adopting a Sanity API feature that requires a newer date.
SANITY_API_VERSION=2026-05-21

# Read token (Viewer role) — never public; server-only.
# Used by: draft-mode preview fetches, SanityLive real-time subscriptions.
# Generate at: Sanity Manage → API → Tokens → Add token (Viewer role).
SANITY_API_READ_TOKEN=

# Write token (Editor role) — never public; used only by migration scripts.
# NOT needed to run the site or Studio. Only set this locally when running
# scripts/migrate-*.mjs to seed content.
# Generate at: Sanity Manage → API → Tokens → Add token (Editor role).
SANITY_API_WRITE_TOKEN=

# ── Site URL ──────────────────────────────────────────────────────────────────

# Full origin of the deployed site.
# Used by: Presentation Tool preview iframe, Next.js metadataBase.
# Local: http://localhost:3000
# Production: https://mayanleague.vercel.app  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Preview site password gate (optional) ───────────────────────────────────────

# When BOTH are set on Vercel, the entire site (including /studio) requires a
# password before viewing. Leave unset for local dev unless you are testing the gate.
#
# PREVIEW_ACCESS_PASSWORD — share this with reviewers (e.g. Mayan League staff).
# PREVIEW_ACCESS_TOKEN    — secret cookie value; never share. Generate once:
#   openssl rand -hex 32
PREVIEW_ACCESS_PASSWORD=
PREVIEW_ACCESS_TOKEN=
