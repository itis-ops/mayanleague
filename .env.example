# --- Sanity CMS ---
# Project ID from https://www.sanity.io/manage (after creating the `mayanleague` project)
NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder-project-id

# Dataset name. Use `production` for the live dataset.
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity Studio + GROQ API version. Pinned to today's date for stability (IETF date-as-version convention).
# Bump only when you need newer Sanity API features and have verified compatibility.
SANITY_API_VERSION=2026-05-21

# Server-only read token. Used later for `previewDrafts` perspective + ISR webhooks.
# Generate at: Sanity Manage > API > Tokens > Add API token (Viewer role).
# Leave blank locally until you wire up draft previews.
SANITY_API_READ_TOKEN=

# --- Site URL (used elsewhere, included here so .env.example stays canonical) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
